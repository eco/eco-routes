
# ============================================================
# deploy-base-tron.ts — environment variables
# ============================================================
# Copy this file to .env (or source it) before running:
#   npx ts-node scripts/deploy-base-tron.ts --testnet --dry-run
# ============================================================

# ── Shared ────────────────────────────────────────────────────
# Hex private key (works for both Base secp256k1 and Tron).
# Remove the 0x prefix if present — the script handles both.
PRIVATE_KEY=

# Arbitrary string; keccak256'd into a deterministic bytes32 salt.
# Keep this consistent across runs to get the same contract addresses.
SALT=eco-routes-v1

# CSV file to append deployment results to.
DEPLOY_FILE=out/deploy.csv

# ── Base (EVM) ────────────────────────────────────────────────
# RPC endpoint for Base.  Defaults to https://sepolia.base.org with --testnet.
BASE_RPC_URL=https://sepolia.base.org

# LayerZero endpoint contract address on Base.
# Testnet (Base Sepolia): 0x6EDCE65403992e310A62460808c4b910D972f10f
# Mainnet (Base):         0x1a44076050125825900e736c501f859c50fE728c
BASE_LZ_ENDPOINT=0x6EDCE65403992e310A62460808c4b910D972f10f

# (Optional) LayerZero OApp delegate on Base. Defaults to the deployer address.
BASE_LZ_DELEGATE=

# (Optional) Skip Portal deployment if already deployed on Base.
BASE_PORTAL_CONTRACT=

# ── Tron ──────────────────────────────────────────────────────
# RPC endpoint for Tron.  Defaults to https://api.shasta.trongrid.io with --testnet.
TRON_RPC_URL=https://api.shasta.trongrid.io

# LayerZero endpoint contract address on Tron (base58 or hex — script handles both).
# Testnet (Shasta):  0x1b356f3030CE0c1eF9D3e1E250Bf0BB11D81b2d1  EID: 40420
# Mainnet (Tron):    0x0Af59750D5dB5460E5d89E268C474d5F7407c061  EID: 30420
TRON_LZ_ENDPOINT=

# (Optional) LayerZero OApp delegate on Tron (base58). Defaults to the deployer address.
TRON_LZ_DELEGATE=

# (Optional) Skip Portal deployment if already deployed on Tron (base58 or hex).
TRON_PORTAL_CONTRACT=

# Create2Factory_Tron address to use for deterministic Tron deployments.
# Defaults to the Shasta testnet factory when --testnet is set:
#   TSh1WRYebthHLcfJ7eFqTyps97jMgbh96g
# Leave blank to use the default, or set to your own deployed factory address.
TRON_CREATE2_FACTORY=
